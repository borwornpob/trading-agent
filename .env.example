# ── Broker Selection ─────────────────────────────────────
# ctrader or mt5
HARD_BROKER=mt5

# ── MT5 Demo via https://github.com/borwornpob/mt5_api ───
# Clone mt5_api and point this to the clone root, e.g.
# MT5_API_PATH=/Users/you/dev/mt5_api
MT5_API_PATH=
MT5_HOST=0.0.0.0
MT5_PORT=1111
MT5_CONNECTION_TIMEOUT_SECONDS=120
MT5_COMMAND_TIMEOUT_SECONDS=45
MT5_MAGIC=240501
MT5_VOLUME_LOTS=0.01

# ── cTrader / ICMarkets ──────────────────────────────────
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=
CTRADER_SYMBOL_ID=
CTRADER_DEMO=true

# ── GenAI (GLM via OpenAI-compatible API) ───────────────
GENAI_API_KEY=
GENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GENAI_MODEL=glm-4-flash

# ── Agent Config ─────────────────────────────────────────
HARD_YAHOO_SYMBOL=GC=F
HARD_BROKER_SYMBOL=XAUUSD
HARD_BAR_FREQUENCY=15m
HARD_SESSION_FILTER=
HARD_SHADOW_MODE=true
HARD_KILL_SWITCH=false
HARD_ENSEMBLE_PRIMARY_WEIGHT=0.65
HARD_VOLUME_UNITS=100
# Optional. If blank, selected automatically from HARD_BAR_FREQUENCY:
# 15m -> gold_lgbm_15m.pkl, 1h -> gold_lgbm_1h.pkl,
# 4h -> gold_lgbm_4h.pkl, daily -> gold_lgbm.pkl.
HARD_MODEL_PATH=
HARD_SR_MODEL_PATH=
HARD_REGIME_MODEL_PATH=

# ── Risk ─────────────────────────────────────────────────
# For MT5 these values are lots. For cTrader units, use 500 and 200.
HARD_MAX_POSITION_VOLUME=0.05
HARD_MAX_ORDER_VOLUME=0.02
HARD_MAX_DAILY_LOSS_UNITS=10000
HARD_GRID_ENABLED=true
HARD_GRID_MAX_LEVELS=3
HARD_GRID_TOTAL_EXPOSURE_CAP=2.0
HARD_GRID_SIZING_DECAY=0.7

# ── GenAI News ───────────────────────────────────────────
GENAI_NEWS_ENABLED=true
GENAI_NEWS_CACHE_HOURS=4
GENAI_NEWS_RSS_FEEDS=https://www.investing.com/rss/news_301.rss,https://www.reuters.com/tools/rss/feed.xml

# ── Dashboard ────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_RELOAD=false
